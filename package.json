{
  "name": "icf-editor",
  "version": "0.1.0",
  "description": "Cross-platform desktop editor for Indent Comma Format (ICF) and ICX index files.",
  "author": "Edison Williams",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "homepage": "https://icformat.org",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "icons": "node scripts/generate-icons.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "package": "npm run icons && npm run build && electron-builder",
    "package:win": "npm run icons && npm run build && electron-builder --win",
    "package:mac": "npm run icons && npm run build && electron-builder --mac",
    "package:linux": "npm run icons && npm run build && electron-builder --linux"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "icf.js": "file:../icf.js",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "png-to-ico": "^2.1.8",
    "@tanstack/react-virtual": "^3.10.0",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-store": "^10.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "happy-dom": "^15.0.0",
    "monaco-editor": "^0.50.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "zustand": "^4.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
